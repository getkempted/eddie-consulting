# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-output
/.playwright-mcp

# local screenshots / scratch PNGs at repo root
/*.png

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local AI tooling / orchestration (not part of the app)
/.agents
/.claude
/MASTER_PROMPT.md
/ORCHESTRATION_RULES.md
/cursor-context.md

# typescript
*.tsbuildinfo
next-env.d.ts
