# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local Supabase (from `supabase start` — use API URL and anon key from CLI output)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only; never expose to the browser. Used by server actions for inserts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Spline scene URL (prod.spline.design)
NEXT_PUBLIC_SPLINE_SCENE_URL=
