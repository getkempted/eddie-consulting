# Directory patterns in .vercelignore follow gitignore syntax: a bare
# pattern like `foo/` matches ANY folder named foo at any depth. To limit
# a rule to the repo root, prefix with a leading slash (e.g. `/foo/`).

# Local testing & screenshot artifacts
/.playwright-mcp/
/playwright-output/
/*.png

# HTML mockups — reference only, not used at runtime
/mockups/

# Planning & documentation (not needed at runtime)
/ARCHITECTURE.md
/PROJECT.md
/ORCHESTRATION_RULES.md
/MASTER_PROMPT.md
/CLAUDE.md
/cursor-context.md

# Editor / tooling
/.vscode/
/.agents/
/.claude/

# Supabase local dev config (Supabase is hosted separately).
# IMPORTANT: leading slash — src/lib/supabase/ MUST NOT be ignored.
/supabase/

# Scripts not needed for runtime
/scripts/
